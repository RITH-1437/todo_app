# ────────────────────────────────────────────────────────────────────────────
# .env.example — Environment variable template.
# Copy this file to .env and fill in your own values.
# NEVER put real credentials here — this file IS committed to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=todo_app
DB_USER=root
DB_PASS=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_NAME=Todo App
